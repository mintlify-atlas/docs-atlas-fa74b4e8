  "keyFeatures": [
    "MVC architecture with convention over configuration",
    "Active Record ORM with migrations and associations",
    "RESTful routing with resourceful conventions",
    "Asset pipeline and JavaScript/CSS management",
    "Background job processing via Active Job",
    "WebSocket support via Action Cable",
    "File upload/cloud storage via Active Storage",
    "Rich text editing via Action Text",
    "Email sending/receiving via Action Mailer/Mailbox",
    "Rails engines for modular, mountable applications",
    "Built-in testing framework with fixtures",
    "Rails CLI with generators for scaffolding"
  ],
  "publicApiSurface": [
